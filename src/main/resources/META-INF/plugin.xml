<idea-plugin>
    <id>pl.lukaszburzak.creye</id>
    <name>CReye</name>
    <vendor>Łukasz Burzak</vendor>
    <description><![CDATA[
        Visualizes Kotlin symbol dependencies for code that changed between a git branch
        and the working directory, as a hierarchical network graph rendered in an editor panel.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>Git4Idea</depends>

    <dependencies>
        <module name="intellij.libraries.compose.foundation.desktop"/>
        <module name="intellij.libraries.skiko"/>
        <module name="intellij.platform.jewel.foundation"/>
        <module name="intellij.platform.jewel.ui"/>
        <module name="intellij.platform.jewel.ideLafBridge"/>
    </dependencies>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="pl.lukaszburzak.creye.ide.DependencyGraphFileEditorProvider"/>
    </extensions>

    <actions>
        <action id="pl.lukaszburzak.creye.ShowDependencyGraph"
                class="pl.lukaszburzak.creye.ide.ShowDependencyGraphAction"
                text="Show Dependency Graph"
                description="Open the Kotlin symbol dependency graph for changes against a git branch">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="pl.lukaszburzak.creye.ApproveSelectedNode"
                class="pl.lukaszburzak.creye.ide.ApproveSelectedNodeAction"
                text="Approve Selected Node"
                description="Toggle approval of the node selected in the dependency graph">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="pl.lukaszburzak.creye.ScopeToSelectedNode"
                class="pl.lukaszburzak.creye.ide.ScopeToSelectedNodeAction"
                text="Scope to Selected Node"
                description="Filter the dependency graph to the selected node and its dependencies">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="pl.lukaszburzak.creye.ToggleApprovalAtCaret"
                class="pl.lukaszburzak.creye.ide.ToggleApprovalAtCaretAction"
                text="Toggle Approval of Symbol with Cursor"
                description="Toggle approval of the changed symbol whose range contains the combined-diff caret"
                icon="AllIcons.Actions.Checked">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift A"/>
        </action>
        <action id="pl.lukaszburzak.creye.ApproveSymbolAtCaret"
                class="pl.lukaszburzak.creye.ide.ApproveSymbolAtCaretAction"
                text="Approve Symbol at Caret"
                description="Toggle approval of the changed symbol nearest the combined-diff caret, even if collapsed in the graph">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="pl.lukaszburzak.creye.CollapseModuleOfSelectedNode"
                class="pl.lukaszburzak.creye.ide.CollapseModuleOfSelectedNodeAction"
                text="Collapse Module of Selected Node"
                description="Collapse the module subtree containing the selected node">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
